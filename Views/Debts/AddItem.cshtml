@model StoreApp.Models.DebtItem

<div class="container mt-4" dir="rtl">

    <h3>إضافة منتج للدين</h3>

    <form asp-action="AddItem" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="CustomerDebtId" />

        <div class="mb-3">

            <label>المنتج</label>

            <select asp-for="ProductId"
                    asp-items="ViewBag.Products"
                    class="form-select"
                    id="productSelect">

                <option value="">اختر المنتج</option>

            </select>

        </div>

        <div class="mb-3">
            <label>السعر</label>

            <input asp-for="Price"
                   type="number"
                   step="0.01"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label>الكمية</label>

            <input asp-for="Quantity" class="form-control" />

        </div>



        <div class="mb-3">

            <label>العملة</label>

            <select asp-for="Currency" class="form-select">

                <option value="USD">دولار $</option>

                <option value="SYP">ليرة سورية</option>

            </select>

        </div>


        <button type="submit" class="btn btn-success">
            إضافة
        </button>

    </form>

</div>
