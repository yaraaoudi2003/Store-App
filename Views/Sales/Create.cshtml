@model StoreApp.Models.Sale

@{
    ViewData["Title"] = "تسجيل عملية بيع";
    var productsJson = Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.Products);
}

<div class="container mt-4" dir="rtl">

    <h3 class="text-center mb-4">تسجيل عملية بيع</h3>

   
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label>اسم المشتري</label>
            <input asp-for="CustomerName" class="form-control" />
        </div>

        <table class="table table-bordered" id="productsTable">
            <thead class="table-dark">
                <tr>
                    <th>المنتج</th>
                    <th>الكمية</th>
                    <th>سعر البيع</th>
                    <th>حذف</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <select name="Items[0].ProductId" class="form-control">
                        </select>
                    </td>
                    <td><input name="Items[0].QuantitySold" class="form-control" /></td>
                    <td><input name="Items[0].SellingPrice" class="form-control" /></td>
                    <td>
                        <button type="button" class="btn btn-danger" onclick="removeRow(this)">
                            حذف
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>

        <button type="button" class="btn btn-primary mb-3" onclick="addRow()">➕ إضافة منتج</button>

        <div class="mt-3">
            <label>عملة البيع</label>
            <select asp-for="SaleCurrency" id="currency" class="form-control" onchange="toggleExchangeRate()">
                <option value="USD">دولار</option>
                <option value="SYP">ليرة سورية</option>
            </select>
        </div>

        <div class="mt-3" id="exchangeDiv" style="display:none">
            <label>سعر الصرف</label>
            <input asp-for="ExchangeRate" class="form-control" placeholder="مثال 15000" />
        </div>

        <br>

        <label>
            <input type="checkbox" asp-for="IsDebt" /> بيع على الحساب
        </label>

        <br>
        <br>

        <button type="submit" class="btn btn-success">تسجيل البيع</button>
        <a asp-controller="Products" asp-action="Index" class="btn btn-secondary">العودة للمنتجات</a>
    </form>

</div>

<script>
    let index = 1;
    let products = @Html.Raw(productsJson);

   
    let firstSelect = document.querySelector("#productsTable select");
    products.forEach(p => {
        let option = document.createElement("option");
        option.value = p.Value;
        option.text = p.Text;   
        firstSelect.appendChild(option);
    });

    function addRow() {
        let table = document.querySelector("#productsTable tbody");
        let tr = document.createElement("tr");

        let tdProduct = document.createElement("td");
        let select = document.createElement("select");
        select.name = `Items[${index}].ProductId`;
        select.className = "form-control";

        products.forEach(p => {
            let option = document.createElement("option");
            option.value = p.Value;
            option.text = p.Text;
            select.appendChild(option);
        });

        tdProduct.appendChild(select);
        tr.appendChild(tdProduct);

        let tdQty = document.createElement("td");
        let qty = document.createElement("input");
        qty.name = `Items[${index}].QuantitySold`;
        qty.className = "form-control";
        tdQty.appendChild(qty);
        tr.appendChild(tdQty);

        let tdPrice = document.createElement("td");
        let price = document.createElement("input");
        price.name = `Items[${index}].SellingPrice`;
        price.className = "form-control";
        tdPrice.appendChild(price);
        tr.appendChild(tdPrice);

        let tdDel = document.createElement("td");
        let btn = document.createElement("button");
        btn.type = "button";
        btn.className = "btn btn-danger";
        btn.innerText = "حذف";
        btn.onclick = function () { removeRow(btn); };
        tdDel.appendChild(btn);
        tr.appendChild(tdDel);

        table.appendChild(tr);
        index++;
    }

    function removeRow(btn) {
        btn.closest("tr").remove();
    }

    function toggleExchangeRate() {
        let currency = document.getElementById("currency").value;
        let div = document.getElementById("exchangeDiv");
        div.style.display = (currency === "SYP") ? "block" : "none";
    }
</script>