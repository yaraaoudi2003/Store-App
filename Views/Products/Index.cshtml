@model IEnumerable<StoreApp.Models.Product>

<div class="container mt-4" dir="rtl">

    <h2 class="mb-4 text-end">إدارة المنتجات</h2>

    <!-- إحصائيات المخزون -->
    <div class="row mb-3">

        <!-- عدد المنتجات -->
        <div class="col-md-4">
            <div class="card bg-primary text-white shadow text-center">
                <div class="card-body">
                    <h6>عدد المنتجات</h6>
                    <h3>@Model.Count()</h3>
                </div>
            </div>
        </div>

        <!-- قيمة المخزون بالدولار -->
        <div class="col-md-4">
            <div class="card bg-success text-white shadow text-center">
                <div class="card-body">
                    <h6>قيمة المخزون بالدولار</h6>
                    <h3>
                        @(Model
                            .Where(p => p.Currency == "USD")
                            .Sum(p => p.initialPrice * p.Quantity))
                        $
                    </h3>
                </div>
            </div>
        </div>

        <!-- قيمة المخزون بالليرة -->
        <div class="col-md-4">
            <div class="card bg-dark text-white shadow text-center">
                <div class="card-body">
                    <h6>قيمة المخزون بالليرة</h6>
                    <h3>
                        @(Model
                            .Where(p => p.Currency == "SYP")
                            .Sum(p => p.initialPrice * p.Quantity))
                        ل.س
                    </h3>
                </div>
            </div>
        </div>

    </div>



    <div class="card shadow-sm mb-3">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap">

            
            <div class="d-flex gap-2">

                <a asp-action="Create" class="btn btn-success">
                    ➕ إضافة منتج
                </a>

                <a asp-controller="Sales" asp-action="Create" class="btn btn-primary">
                    💰 تسجيل عملية بيع
                </a>

                <a asp-controller="Sales" asp-action="Index" class="btn btn-dark">
                    📊 عرض المبيعات
                </a>
                <a asp-controller="Debts" asp-action="Index" class="btn btn-danger">
                    📒  الديون
                </a>

            </div>

           
            <form method="get" class="d-flex mt-2 mt-md-0">

                <input type="text"
                       name="search"
                       class="form-control ms-2"
                       placeholder="ابحث عن منتج...">

                <button class="btn btn-outline-primary">
                    بحث
                </button>

            </form>

        </div>
    </div>



    <table class="table table-striped table-bordered table-hover text-center">

        <thead class="table-dark">
            <tr>
                <th>اسم المنتج</th>
                <th>الكمية</th>
                <th>سعر الشراء</th>
                <th>سعر المبيع</th>
                <th>السعر الإجمالي</th>
                <th>التاريخ</th>
                <th>العمليات</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>

                    <td>@item.Name</td>

                    <td>@item.Quantity</td>

                    <td>
                        @item.initialPrice
                        @(item.Currency == "USD" ? "$" : "ل.س")
                    </td>

                    <td>
                        @item.UnitPrice
                        @(item.Currency == "USD" ? "$" : "ل.س")
                    </td>

                    <td class="fw-bold text-primary">
                        @item.TotalPrice
                        @(item.Currency == "USD" ? "$" : "ل.س")
                    </td>

                    <td>
                        @item.Date.ToString("yyyy-MM-dd HH:mm")
                    </td>

                    <td>

                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">
                            تعديل
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">
                            حذف
                        </a>

                        <a asp-action="Details" asp-route-id="@item.Id"
                           class="btn btn-info btn-sm">
                            التفاصيل
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>